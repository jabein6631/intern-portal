{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
, "app/layout.jsx", "components/dashboard/progress-performance.jsx", "app/page.jsx", "app/intern/dashboard/page.jsx", "components/theme-provider.jsx", "components/dashboard/topbar.jsx", "components/dashboard/stat-cards.jsx", "components/dashboard/sidebar.jsx", "components/dashboard/activities-deadlines.jsx", "app/signup/page.jsx"  ],
  "exclude": [
    "node_modules"
  ]
}
